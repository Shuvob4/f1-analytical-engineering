# AWS credentials (fill in .env, never commit real values)
AWS_ACCESS_KEY_ID=your_key_here
AWS_SECRET_ACCESS_KEY=your_secret_here
AWS_REGION=eu-west-1

# S3 buckets
S3_BUCKET_BRONZE=your-initials-f1-data-bronze
S3_BUCKET_SILVER=your-initials-f1-data-silver
S3_BUCKET_GOLD=your-initials-f1-data-gold

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_F1_LIVE=f1-live-timing